# ===============================
# SOC Dashboard - Exemplo de .env
# ===============================
# Copie este arquivo para .env e ajuste os valores.
# Exemplo:
#   cp .env.example .env

# PostgreSQL
POSTGRES_USER=admin
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=soc_dashboard

# Backend
BACKEND_PORT=3001
NODE_ENV=production

# Frontend (nginx)
FRONTEND_PORT=80

# CORS (separar múltiplas origens por vírgula)
CORS_ORIGIN=http://localhost:80,http://localhost:5173

# String de conexão usada pelo backend
DATABASE_URL=postgres://admin:change_me_strong_password@postgres:5432/soc_dashboard
